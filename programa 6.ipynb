   "source": [
    "temp= [80, 72, 95, 82, 79, 72, 85]\n",
    "temp_n = []                            \n",
    "for t in temp:\n",
    "    c = (t - 32) * 5/9                 \n",
    "    temp_n.append(round(c, 2))          \n",
    "\n",
    "print(\"Fahrenheit:\", temp)\n",
    "print(\"Celsius:\", temp_n)"
   ]
  }
